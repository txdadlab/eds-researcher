# xAI / Grok API key (console.x.ai)
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx

# PubMed / NCBI API key (ncbi.nlm.nih.gov/account)
NCBI_API_KEY=your_ncbi_api_key_here

# Reddit API credentials (reddit.com/prefs/apps -> create "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=eds-researcher/0.1.0
